{
  "name": "@adullamtech/norm",
  "version": "0.1.0",
  "description": "A Notion ORM for TypeScript. Define Notion-backed models with a declarative schema, retrieve/create pages with type safety.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "zod": "^4.4.3",
    "@notionhq/client": "^5.14.0"
  },
  "devDependencies": {
    "@notionhq/client": "^5.14.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}