{
  "name": "@adullamtech/norm",
  "version": "0.1.13",
  "description": "A Notion ORM for TypeScript. Define Notion-backed models with a declarative schema, retrieve/create pages with type safety.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Adullam Technologies",
    "url": "https://adullamtech.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adullam-Technologies/norm.git"
  },
  "homepage": "https://github.com/Adullam-Technologies/norm#readme",
  "bugs": {
    "url": "https://github.com/Adullam-Technologies/norm/issues"
  },
  "keywords": [
    "notion",
    "orm",
    "typescript",
    "notion-api",
    "type-safe",
    "zod",
    "database",
    "schema"
  ],
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@notionhq/client": "^5.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@notionhq/client": "^5.14.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.0.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
